# ============================================================================
# Knowledge Graph Chatbot — Environment Variables
# Copy this to .env and customize as needed.
# ============================================================================

# --- JWT Authentication ---
JWT_SECRET=change-me-to-a-strong-random-secret

# --- PostgreSQL ---
POSTGRES_USER=kgchat
POSTGRES_PASSWORD=kgchat-dev-password
POSTGRES_DB=kgchat

# --- LLM Configuration ---
# Ollama model to use (pulled automatically on first run)
OLLAMA_MODEL=llama3.1:8b

# OpenAI API key (optional fallback when Ollama is unavailable)
OPENAI_API_KEY=

# --- Embedding Model ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Topic Domain ---
TOPIC_DOMAIN=Cybersecurity threat intelligence and CVE vulnerabilities
